{
  "name": "fried-ui",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:docs": "turbo build --filter=docs",
    "build:react": "turbo build --filter=@fried-ui/react",
    "build:storybook": "turbo build --filter=storybook",
    "build:styles": "turbo build --filter=@fried-ui/styles",
    "build:web": "turbo build --filter=web",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "clean:cache": "rm -rf .turbo node_modules/.cache",
    "clean:dist": "turbo clean",
    "clean:docs": "turbo clean --filter=docs",
    "clean:react": "turbo clean --filter=@fried-ui/react",
    "clean:storybook": "turbo clean --filter=storybook",
    "clean:styles": "turbo clean --filter=@fried-ui/styles",
    "clean:web": "turbo clean --filter=web",
    "dev": "turbo dev",
    "dev:docs": "turbo dev --filter=docs",
    "dev:react": "turbo dev --filter=@fried-ui/react",
    "dev:storybook": "turbo dev --filter=storybook",
    "dev:styles": "turbo dev --filter=@fried-ui/styles",
    "dev:web": "turbo dev --filter=web",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,css,md,mdx}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,css,md,mdx}\"",
    "preinstall": "npx only-allow pnpm",
    "lint": "turbo lint",
    "lint:docs": "turbo lint --filter=docs",
    "lint:fix": "turbo lint -- --fix",
    "lint:react": "turbo lint --filter=@fried-ui/react",
    "lint:storybook": "turbo lint --filter=storybook",
    "lint:styles": "turbo lint --filter=@fried-ui/styles",
    "lint:web": "turbo lint --filter=web",
    "prepare": "husky",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo check-types",
    "typecheck:docs": "turbo check-types --filter=docs",
    "typecheck:react": "turbo check-types --filter=@fried-ui/react",
    "typecheck:storybook": "turbo check-types --filter=storybook",
    "typecheck:styles": "turbo check-types --filter=@fried-ui/styles",
    "typecheck:web": "turbo check-types --filter=web"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@repo/quality": "workspace:*",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sort-package-json": "^3.6.1",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
