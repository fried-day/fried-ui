{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["eslint.config.ts", "prettier.config.mjs", "lint-staged.config.mjs"],
  "exclude": ["node_modules", "apps", "packages"]
}
