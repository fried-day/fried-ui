import { createRef } from "react";

import { render, screen } from "@testing-library/react";
import userEvent from "@testing-library/user-event";
import { describe, expect, it, vi } from "vitest";

import { {{Name}} } from "./{{Name}}";

describe("{{Name}}", () => {
  it("renders with default props", () => {
    render(<{{Name}}>Content</{{Name}}>);
    expect(screen.getByText("Content")).toBeInTheDocument();
  });

  it("renders only base class without explicit props", () => {
    render(<{{Name}}>Default</{{Name}}>);
    const el = screen.getByText("Default");
    expect(el.className).toContain("fri-{{name}}");
    expect(el.className).not.toContain("fri-{{name}}--primary");
    expect(el.className).not.toContain("fri-{{name}}--size-md");
  });

  it("applies variant class only when explicitly set", () => {
    render(<{{Name}} variant="primary">Test</{{Name}}>);
    expect(screen.getByText("Test").className).toContain("fri-{{name}}--primary");
  });

  it("applies all variant classes", () => {
    const variants = ["primary", "secondary", "ghost", "outline", "success", "warning", "danger", "info"] as const;

    variants.forEach((variant) => {
      const { unmount } = render(<{{Name}} variant={variant}>{variant}</{{Name}}>);
      expect(screen.getByText(variant).className).toContain(`fri-{{name}}--${variant}`);
      unmount();
    });
  });

  it("applies size class with key-value format", () => {
    const sizes = ["sm", "md", "lg"] as const;

    sizes.forEach((size) => {
      const { unmount } = render(<{{Name}} size={size}>{size}</{{Name}}>);
      expect(screen.getByText(size).className).toContain(`fri-{{name}}--size-${size}`);
      unmount();
    });
  });

  it("merges custom className", () => {
    render(<{{Name}} className="mt-4">Styled</{{Name}}>);
    expect(screen.getByText("Styled").className).toContain("mt-4");
  });

  it("forwards ref", () => {
    const ref = createRef<HTMLElement>();
    render(<{{Name}} ref={ref}>Ref</{{Name}}>);
    expect(ref.current).toBeInstanceOf(HTMLElement);
  });

  it("sets data-slot attribute", () => {
    render(<{{Name}}>Slot</{{Name}}>);
    expect(screen.getByText("Slot")).toHaveAttribute("data-slot", "{{name}}");
  });

  it("sets displayName", () => {
    expect({{Name}}.displayName).toBe("{{Name}}");
  });

  it("applies disabled class", () => {
    render(<{{Name}} isDisabled>Disabled</{{Name}}>);
    expect(screen.getByText("Disabled").className).toContain("fri-{{name}}--disabled");
  });

  it("renders as disabled", () => {
    render(<{{Name}} isDisabled>Disabled</{{Name}}>);
    expect(screen.getByText("Disabled").closest("[data-slot]")).toBeDisabled();
  });

  it("fires onPress when clicked", async () => {
    const onPress = vi.fn();
    const user = userEvent.setup();
    render(<{{Name}} onPress={onPress}>Press</{{Name}}>);

    await user.click(screen.getByText("Press"));

    expect(onPress).toHaveBeenCalledOnce();
  });

  it("does not fire onPress when disabled", async () => {
    const onPress = vi.fn();
    const user = userEvent.setup();

    render(
      <{{Name}} onPress={onPress} isDisabled>
        Disabled
      </{{Name}}>,
    );

    await user.click(screen.getByText("Disabled"));

    expect(onPress).not.toHaveBeenCalled();
  });

  it("supports className as render prop function", () => {
    render(
      <{{Name}} className={({ isHovered }): string => (isHovered ? "hovered" : "idle")}>Dynamic</{{Name}}>,
    );

    expect(screen.getByText("Dynamic").className).toContain("fri-{{name}}");
    expect(screen.getByText("Dynamic").className).toContain("idle");
  });

  it("passes through native HTML attributes", () => {
    render(
      <{{Name}} data-testid="custom-{{name}}">
        Props
      </{{Name}}>,
    );

    expect(screen.getByTestId("custom-{{name}}")).toBeInTheDocument();
  });
});
