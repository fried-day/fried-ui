{
  "name": "@fried-ui/styles",
  "version": "0.0.0",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.css",
    "./variants": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs"
    }
  },
  "files": [
    "dist",
    "src/index.css"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/quality": "workspace:*",
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  }
}
