{
  "name": "@fried-ui/styles",
  "version": "0.1.0",
  "description": "Theme engine, design tokens, and component presets for fried-ui",
  "keywords": [
    "tailwindcss",
    "styles",
    "variants",
    "css",
    "design-system",
    "tailwind-variants"
  ],
  "homepage": "https://github.com/fried-day/fried-ui",
  "bugs": "https://github.com/fried-day/fried-ui/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/fried-day/fried-ui",
    "directory": "packages/styles"
  },
  "license": "MIT",
  "author": "Joe Takara <anuchit.boonsom@gmail.com>",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.css",
    "./variants": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs"
    }
  },
  "files": [
    "dist",
    "src/index.css"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/quality": "workspace:*",
    "@tailwindcss/cli": "^4.2.2",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
